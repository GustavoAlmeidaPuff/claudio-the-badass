{
  "name": "Claudio-the-badass-vscode",
  "displayName": "Claudio, The Badass",
  "description": "Practical VS Code companion for Claudio, The Badass with project-aware launch behavior and a real Control Center.",
  "version": "0.1.1",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:Claudio-the-badass.start",
    "onCommand:Claudio-the-badass.startInWorkspaceRoot",
    "onCommand:Claudio-the-badass.openDocs",
    "onCommand:Claudio-the-badass.openSetupDocs",
    "onCommand:Claudio-the-badass.openWorkspaceProfile",
    "onCommand:Claudio-the-badass.openControlCenter",
    "onView:Claudio-the-badass.controlCenter"
  ],
  "main": "./src/extension.js",
  "files": [
    "README.md",
    "media/**",
    "src/extension.js",
    "src/presentation.js",
    "src/state.js",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "Claudio-the-badass.start",
        "title": "Claudio, The Badass: Launch in Terminal",
        "category": "Claudio, The Badass"
      },
      {
        "command": "Claudio-the-badass.startInWorkspaceRoot",
        "title": "Claudio, The Badass: Launch in Workspace Root",
        "category": "Claudio, The Badass"
      },
      {
        "command": "Claudio-the-badass.openDocs",
        "title": "Claudio, The Badass: Open Repository",
        "category": "Claudio, The Badass"
      },
      {
        "command": "Claudio-the-badass.openSetupDocs",
        "title": "Claudio, The Badass: Open Setup Guide",
        "category": "Claudio, The Badass"
      },
      {
        "command": "Claudio-the-badass.openWorkspaceProfile",
        "title": "Claudio, The Badass: Open Workspace Profile",
        "category": "Claudio, The Badass"
      },
      {
        "command": "Claudio-the-badass.openControlCenter",
        "title": "Claudio, The Badass: Open Control Center",
        "category": "Claudio, The Badass"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "Claudio-the-badass",
          "title": "Claudio, The Badass",
          "icon": "media/Claudio-the-badass.svg"
        }
      ]
    },
    "views": {
      "Claudio-the-badass": [
        {
          "id": "Claudio-the-badass.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Claudio, The Badass",
      "properties": {
        "Claudio-the-badass.launchCommand": {
          "type": "string",
          "default": "Claudio-the-badass",
          "description": "Command run in the integrated terminal when launching Claudio, The Badass."
        },
        "Claudio-the-badass.terminalName": {
          "type": "string",
          "default": "Claudio, The Badass",
          "description": "Integrated terminal tab name for Claudio, The Badass sessions."
        },
        "Claudio-the-badass.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Optionally set CLAUDIO_THE_BADASS_USE_OPENAI=1 in launched Claudio, The Badass terminals."
        }
      }
    },
    "themes": [
      {
        "label": "Claudio, The Badass Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/Claudio, The Badass-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "test": "node --test ./src/*.test.js",
    "lint": "node -e \"for (const file of require('node:fs').readdirSync('./src')) { if (file.endsWith('.js')) { require('node:child_process').execFileSync(process.execPath, ['--check', require('node:path').join('src', file)], { stdio: 'inherit' }); } }\"",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "keywords": [
    "Claudio-the-badass",
    "terminal",
    "theme",
    "cli",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Gitlawb/Claudio-the-badass"
  },
  "license": "MIT"
}
